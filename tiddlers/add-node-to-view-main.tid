title: add-node-to-view-main
type: text/vnd.tiddlywiki
tags: $:/tags/Macro

\define add-node-to-view-main()
<$set name="viewName" filter="[all[current]get[titleresearch]!is[blank]]" emptyValue={{!!title}}>
<$transclude $variable="addNodeToView"
  nodeName={{$:/state/newNodeTemp!!node}}
  main=true
  nodeGraph={{$:/state/newNodeTemp!!nodegraph}}
  view=<<viewName>>/>
</$set>
\end